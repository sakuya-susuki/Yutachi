    <!-- 粒子脚本 -->
    <script>
      const canvas = document.getElementById('particle-canvas') as HTMLCanvasElement;
      if (canvas) {
        const ctx = canvas.getContext('2d')!;
        let width = (canvas.width = window.innerWidth);
        let height = (canvas.height = window.innerHeight);

        const particles: Particle[] = [];
        const count = 50; 

        class Particle {
          x: number = 0;
          y: number = 0;
          size: number = 0;
          speedX: number = 0;
          speedY: number = 0;
          alpha: number = 0;
          color: string = '';

          constructor() {
            this.reset(true);
          }

          reset(init = false) {
            this.x = Math.random() * width;
            this.y = init ? Math.random() * height : -10;
            this.size = Math.random() * 1.2 + 0.5;
            this.speedX = (Math.random() - 0.5) * 0.1;
            this.speedY = Math.random() * 0.15 + 0.08;
            this.alpha = Math.random() * 0.35 + 0.08;
            
            const isPink = Math.random() > 0.8;
            this.color = isPink 
              ? `rgba(244, 63, 94, ${this.alpha})` 
              : `rgba(226, 232, 240, ${this.alpha})`;
          }

          update() {
            this.x += this.speedX;
            this.y += this.speedY;

            if (this.y > height + 10 || this.x < -10 || this.x > width + 10) {
              this.reset();
            }
          }

          draw() {
            ctx.fillStyle = this.color;
            ctx.beginPath();
            ctx.arc(this.x, this.y, this.size, 0, Math.PI * 2);
            ctx.fill();
          }
        }

        function init() {
          for (let i = 0; i < count; i++) {
            particles.push(new Particle());
          }
        }

        function animate() {
          ctx.clearRect(0, 0, width, height);
          particles.forEach((p) => {
            p.update();
            p.draw();
          });
          requestAnimationFrame(animate);
        }

        window.addEventListener('resize', () => {
          width = canvas.width = window.innerWidth;
          height = canvas.height = window.innerHeight;
        });

        init();
        animate();
      }
    </script>

    <!-- 动态时辰计算脚本 -->
    <script is:inline>
      function updateTimeGreeting() {
        const greetingElement = document.getElementById('dynamic-greeting');
        if (!greetingElement) return;

        const hour = new Date().getHours();
        let greeting = "仲夏蝉鸣";

        if (hour >= 5 && hour < 9) {
          greeting = "晨光熹微";
        } else if (hour >= 9 && hour < 12) {
          greeting = "微风和煦";
        } else if (hour >= 12 && hour < 17) {
          greeting = "暖阳午后";
        } else if (hour >= 17 && hour < 19) {
          greeting = "落日黄昏";
        } else if (hour >= 19 && hour < 23) {
          greeting = "万家灯火";
        } else {
          greeting = "夜深静谧";
        }

        greetingElement.innerText = greeting;
      }
      updateTimeGreeting();
    </script>

<!-- 移动端 -->
 <script is:inline>
      function setupMobileMenu() {
        const btn = document.getElementById('mobile-menu-btn');
        const menu = document.getElementById('nav-menu-wrapper');

        if (!btn || !menu) return;

        // 1. 清除可能残留的旧事件（防止页面切换时重复绑定导致闪烁）
        const newBtn = btn.cloneNode(true);
        btn.parentNode.replaceChild(newBtn, btn);

        // 2. 绑定点击展开/收起事件
        newBtn.addEventListener('click', () => {
          menu.classList.toggle('open');
          console.log('汉堡菜单点击成功！状态：', menu.classList.contains('open'));
        });

        // 3. 点击菜单里的任意链接后，自动收起菜单
        const links = menu.querySelectorAll('a');
        links.forEach(link => {
          link.addEventListener('click', () => {
            menu.classList.remove('open');
          });
        });
      }

      // 无论页面怎么加载，保证 100% 绑定成功
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', setupMobileMenu);
      } else {
        setupMobileMenu();
      }
      
      // 兼容 Astro 的无缝换页功能
      document.addEventListener('astro:page-load', setupMobileMenu);
      document.addEventListener('astro:after-swap', setupMobileMenu);
    </script>

  </body>
