---
import { getCollection, render } from 'astro:content';
import { getPosts } from '../../lib/notion.js';
import BaseLayout from '../../layouts/BaseLayout.astro';
import ScrollProgress from '../../components/ScrollProgress.astro';

export async function getStaticPaths() {
  console.log("🚀 正在运行 getStaticPaths，准备抓取 Notion 数据..."); // <--- 加上这一行

  const localEntries = await getCollection('blog');
// 1. 获取所有路径
export async function getStaticPaths() {
  const localEntries = await getCollection('blog');
  const localPaths = localEntries.map(e => ({ 
    params: { slug: e.id.replace(/\.md$/, '') }, 
    props: { source: 'local', entry: e } 
  }));

  const notionPosts = await getPosts();
  const notionPaths = notionPosts.map(p => ({ 
    params: { slug: p.id }, 
    props: { source: 'notion', entry: p } 
  }));

  return [...localPaths, ...notionPaths];
}}

const { source, entry } = Astro.props;

// 2. 渲染本地 Markdown 内容
const { Content } = source === 'local' ? await render(entry) : { Content: null };

// 3. 标题与描述处理 (兼容 Notion 和本地)
const title = source === 'local' ? entry.data.title : (entry.properties.Name?.title[0]?.plain_text || '文章');
const description = source === 'local' ? entry.data.description : 'Notion 文章';

// 注意：这里需要你后续添加 notion-to-md 转换逻辑
const notionHtml = ""; 
---

<BaseLayout title={title} description={description}>
  
  <div class="scroll-container" style="max-width: 700px; width: 100%; margin: 0 auto; padding: 80px 20px 40px 20px; box-sizing: border-box;">
    <article>
      <header style="margin-bottom: 30px; display: flex; flex-direction: column; gap: 10px;">
        <span class="sub-title" style="font-size: 0.8em; color: var(--accent-color, #d33a50); letter-spacing: 2px;">
          | {source === 'local' ? (entry.data.category || '文章') : 'Notion 文章'}
        </span>
        <h1 class="serif-font" style="font-size: 2.2em; margin: 0; line-height: 1.4; font-weight: 400;">
          {title}
        </h1>
        {source === 'local' && (
          <time style="color: var(--text-muted, #858585); font-size: 0.9em;">
            | {entry.data.pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
        )}
      </header>

      <hr style="border: none; height: 1px; background-color: var(--border-color, #eef0f2); margin-bottom: 40px;" />

      <div class="markdown-body serif-font" style="line-height: 1.8; font-size: 1.05em;">
        {source === 'local' ? (
           <Content />
        ) : (
           <Fragment set:html={notionHtml} />
        )}
      </div>

      <div class="comments-section" style="margin-top: 80px; padding-top: 40px; border-top: 1px dashed var(--border-color);">
        <h3 class="serif-font" style="margin-bottom: 30px; font-size: 1.5rem; color: var(--text-color);">留言</h3>
        <div id="waline"></div>
      </div>
    </article>
  </div>

  <ScrollProgress />
</BaseLayout>

<!-- Waline 样式 -->
<link rel="stylesheet" href="https://unpkg.com/@waline/client@v3/dist/waline.css" />

<style is:global>
  /* 你的 CSS 保持原样不变 */
  :root {
    --waline-theme-color: var(--accent-color) !important;
    --waline-active-color: var(--accent-color) !important;
    --waline-color: var(--text-color) !important;
    --waline-bgcolor: transparent !important;
    --waline-border-color: var(--border-color) !important;
  }
  /* ...此处省略你原有的其他样式，保持完整... */
</style>

<script type="module">
  import { init } from 'https://unpkg.com/@waline/client@v3/dist/waline.js';
  const initWaline = () => {
    const el = document.getElementById('waline');
    if (el) {
      init({ el, serverURL: 'https://comment.ksay.dpdns.org', login: 'disable', emoji: ['https://unpkg.com/@waline/emojis@1.2.0/bilibili'] });
    }
  };
  initWaline();
  document.addEventListener('astro:after-swap', initWaline);
</script>