---
// src/pages/page.astro
import { getCollection } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';

// 1. 【放行随记】把 id.startsWith('随记/') 也加进判断条件中
const pagePosts = await getCollection('blog', ({ id }) => {
  return id.startsWith('文章/') || id.startsWith('思考/') || id.startsWith('随记/');
});

// 2. 【增加分类映射】告诉前端，随记文件夹对应分类名为“记”
pagePosts.forEach(post => {
  if (post.id.startsWith('文章/')) {
    post.data.category = '文';
  } else if (post.id.startsWith('思考/')) {
    post.data.category = '思';
  } else if (post.id.startsWith('随记/')) {
    post.data.category = '记'; 
  }
});
// ... 下面的排序 (sortedPosts) 和 标签 (tagMap) 代码保持不变

// 3. 按发布日期从新到旧排序
const sortedPosts = pagePosts.sort((a, b) => {
  const dateA = a.data.pubDate ? new Date(a.data.pubDate).getTime() : 0;
  const dateB = b.data.pubDate ? new Date(b.data.pubDate).getTime() : 0;
  return dateB - dateA;
});

// 4. 寻找置顶文章
const pinnedPost = sortedPosts.find(post => post.data.pinned === true) || sortedPosts[0];

// 5. 统计标签数 (过滤掉空标签)
const tagMap = {};
pagePosts.forEach(post => {
  const tags = post.data.tags || [];
  tags.forEach(tag => {
    tagMap[tag] = (tagMap[tag] || 0) + 1;
  });
});

const sortedTags = Object.entries(tagMap)
  .sort((a, b) => b[1] - a[1])
  .slice(0, 10);
---

<BaseLayout title="文章列表 - Yutachi">
  <div class="archive-layout">
    
    <!-- 左侧：文章列表大栏 -->
    <main class="archive-main">
      
      <header class="archive-title-section">
        <span class="sub-title">BLOG</span>
        <h1 class="serif-font title-transition" id="page-main-title">文章</h1>
        
        <!-- 新增：文与思的分类筛选器 -->
       <!-- 新增：文与思的分类筛选器 -->
        <div class="category-filters">
          <span class="cat-btn active" data-cat="all">全部</span>
          <span class="cat-btn" data-cat="文">文</span>
          <span class="cat-btn" data-cat="思">思</span>
          <span class="cat-btn" data-cat="记">记</span> 
          <p class="category-desc title-transition" id="category-desc-text">这里汇集了所有的记录与思考。</p>      
        </div>
      </header>

      <!-- 置顶文章 (加上 data-category 参与筛选) -->
      {pinnedPost && (
        <div class="post-item pinned-item" 
             data-category={pinnedPost.data.category} 
             data-tags={JSON.stringify(pinnedPost.data.tags || [])}
             data-date={pinnedPost.data.pubDate ? new Date(pinnedPost.data.pubDate).getTime() : 0}>
          <h2 class="serif-font">
            <a href={`/blog/${pinnedPost.id}`}>{pinnedPost.data.title}</a>
          </h2>
          <p class="post-desc">{pinnedPost.data.description || '点击阅读这篇置顶文章正文...'}</p>
          <div class="archive-post-meta">
            <span class="pinned-tag">置顶</span>
            <span>{pinnedPost.data.pubDate ? new Date(pinnedPost.data.pubDate).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' }) : ''}</span>
            {pinnedPost.data.category && <span class="category-text"> · {pinnedPost.data.category}</span>}
          </div>
        </div>
      )}

      <!-- 分割控制条 (文章统计 & 排序) -->
      <div class="list-control-bar">
        <div class="total-count" id="post-count-display">共 {pagePosts.length} 篇</div>
        <div class="sort-options">
          <span class="sort-btn active" data-sort="newest">最新</span>
          <span class="sort-btn" data-sort="oldest">最早</span>
          <span class="sort-btn" data-sort="updated">最近更新</span>
        </div>
      </div>

      <!-- 普通文章列表 -->
      <div class="regular-posts-list" id="posts-list-container">
        {sortedPosts.map((post) => (
          <div class="post-item" 
               data-category={post.data.category}
               data-tags={JSON.stringify(post.data.tags || [])}
               data-date={post.data.pubDate ? new Date(post.data.pubDate).getTime() : 0}
               data-updated={post.data.updatedDate ? new Date(post.data.updatedDate).getTime() : (post.data.pubDate ? new Date(post.data.pubDate).getTime() : 0)}>
            <h3 class="serif-font">
              <a href={`/blog/${post.id}`}>{post.data.title}</a>
            </h3>
            <p class="post-desc">{post.data.description || '这是一篇关于文字记录的报告，请查收...'}</p>
            <div class="archive-post-meta">
              {post.data.pinned && <span class="pinned-tag-mini">置顶</span>}
              <span>{post.data.pubDate ? new Date(post.data.pubDate).toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' }) : ''}</span>
              {post.data.category && <span class="category-text"> · {post.data.category}</span>}
              {post.data.tags && post.data.tags.slice(0, 3).map((tag) => (
                <span class="tag-pill" data-tag={tag}>{tag}</span>
              ))}
            </div>
          </div>
        ))}
      </div>

    </main>

    <!-- 右侧：侧边栏 -->
    <aside class="archive-sidebar">
      <div class="sidebar-sticky-card">
        <div class="search-box-wrapper">
          <svg class="search-icon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
          </svg>
          <input type="text" placeholder="搜索文章标题..." id="search-input" autocomplete="off" />
        </div>

        <div class="sidebar-section">
          <div class="section-title">热门标签</div>
          <div class="tags-grid">
            {sortedTags.map(([tag, count]) => (
              <span class="tag-badge" data-tag={tag}>
                {tag} <span class="tag-count">({count})</span>
              </span>
            ))}
          </div>
          <a href="#" class="all-tags-link" id="clear-tag-filter">清除标签过滤</a>
        </div>
      </div>
    </aside>

  </div>
</BaseLayout>

<script>
  const initBlogEngine = () => {
    // DOM 元素获取 
    const descEl = document.getElementById('category-desc-text');
    const titleEl = document.getElementById('page-main-title');
    const searchInput = document.getElementById('search-input') as HTMLInputElement;
    const countDisplay = document.getElementById('post-count-display');
    const listContainer = document.getElementById('posts-list-container');
    const postItems = document.querySelectorAll('.post-item') as NodeListOf<HTMLElement>;
    const catBtns = document.querySelectorAll('.cat-btn');
    const tagBadges = document.querySelectorAll('.tag-badge');
    const tagPills = document.querySelectorAll('.tag-pill');
    const clearFilterBtn = document.getElementById('clear-tag-filter');
    const sortBtns = document.querySelectorAll('.sort-btn');
    const catDescriptions = {
      'all': '这里汇集了所有的记录与思考。',
      '文': '正式撰写的文章与长篇论述。',
      '思': '碎片化的想法、灵感与思考瞬间。',
      '记': '日常生活、随笔与毫无主题的记录。'
    };

    // 状态机 
    let state = {
      search: '',
      tag: '',
      cat: 'all' // 'all', '文', '思'
    };

    //  性能优化：预解析数据 
    // 避免在每次过滤时进行高耗时的 DOM 查询和 JSON.parse
    const itemDataCache = Array.from(postItems).map(item => {
      let tags = [];
      try { tags = JSON.parse(item.getAttribute('data-tags') || '[]').map(t => t.toLowerCase()); } catch(e){}
      
      const rawCat = item.getAttribute('data-category') || '';
      // 归一化分类，将 "文章" 归类为 "文"
      const normalizedCat = (rawCat === '文章' || rawCat === '文') ? '文' : rawCat;

      return {
        el: item,
        title: item.querySelector('h3, h2')?.textContent?.toLowerCase() || '',
        desc: item.querySelector('.post-desc')?.textContent?.toLowerCase() || '',
        tags: tags,
        cat: normalizedCat,
        date: Number(item.getAttribute('data-date') || 0),
        updated: Number(item.getAttribute('data-updated') || item.getAttribute('data-date') || 0)
      };
    });

    //  核心过滤渲染 
    const renderView = () => {
      let visibleCount = 0;

      itemDataCache.forEach(data => {
        const matchesSearch = data.title.includes(state.search) || data.desc.includes(state.search);
        const matchesTag = !state.tag || data.tags.includes(state.tag);
        const matchesCat = state.cat === 'all' || data.cat === state.cat;

        if (matchesSearch && matchesTag && matchesCat) {
          data.el.classList.remove('filtered-out');
          visibleCount++;
        } else {
          data.el.classList.add('filtered-out');
        }
      });

      // 动态更新篇数统计
      if(countDisplay) {
        countDisplay.textContent = `共 ${visibleCount} 篇`;
      }

      if(titleEl && descEl) {
        titleEl.classList.add('fade-out');
        descEl.classList.add('fade-out');
        setTimeout(() => {
          titleEl.textContent = state.cat === 'all' ? '文章' : `文章.${state.cat}`;

          descEl.textContent = catDescriptions[state.cat] || catDescriptions['all']; 
          titleEl.classList.remove('fade-out');
          descEl.classList.remove('fade-out');
        }, 200); // 配合 CSS 中的 0.2s 动画
      }
    };

    // 事件监听

    // 1. 分类筛选
    catBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        catBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        state.cat = btn.getAttribute('data-cat') || 'all';
        renderView();
      });
    });

    // 2. 搜索框 (处理中文输入法问题)
    let isComposing = false;
    if(searchInput) {
      searchInput.addEventListener('compositionstart', () => { isComposing = true; });
      searchInput.addEventListener('compositionend', () => {
        isComposing = false;
        state.search = searchInput.value.toLowerCase().trim();
        renderView();
      });
      searchInput.addEventListener('input', () => {
        if (isComposing) return;
        state.search = searchInput.value.toLowerCase().trim();
        renderView();
      });
    }

    // 3. 标签云与药丸联动
    const updateTagUI = (targetTag: string) => {
      state.tag = targetTag;
      tagBadges.forEach(b => {
        if (b.getAttribute('data-tag')?.toLowerCase() === targetTag) {
          b.classList.add('active');
        } else {
          b.classList.remove('active');
        }
      });
      renderView();
    };

    tagBadges.forEach(badge => {
      badge.addEventListener('click', () => {
        const tag = badge.getAttribute('data-tag')?.toLowerCase() || '';
        updateTagUI(state.tag === tag ? '' : tag);
      });
    });

    tagPills.forEach(pill => {
      pill.addEventListener('click', (e) => {
        e.stopPropagation(); 
        e.preventDefault();
        const tag = pill.getAttribute('data-tag')?.toLowerCase() || '';
        updateTagUI(state.tag === tag ? '' : tag);
      });
    });

    if (clearFilterBtn) {
      clearFilterBtn.addEventListener('click', (e) => {
        e.preventDefault();
        updateTagUI('');
      });
    }

    // 4. 排序逻辑
    sortBtns.forEach(btn => {
      btn.addEventListener('click', () => {
        if (!listContainer) return;
        
        sortBtns.forEach(b => b.classList.remove('active'));
        btn.classList.add('active');
        const sortType = btn.getAttribute('data-sort');

        // 执行排序
        listContainer.classList.add('sorting-transition');
        setTimeout(() => {
          const regularItems = itemDataCache.filter(d => !d.el.classList.contains('pinned-item'));
          
          regularItems.sort((a, b) => {
            if (sortType === 'oldest') return a.date - b.date;
            if (sortType === 'updated') return b.updated - a.updated;
            return b.date - a.date; // newest
          });

          regularItems.forEach(item => {
            listContainer.appendChild(item.el); 
          });
          
          listContainer.classList.remove('sorting-transition');
        }, 150);
        
      });
    });
  };

  // Astro 视图过渡支持
  initBlogEngine();
  document.addEventListener('astro:after-swap', initBlogEngine);
</script>

<style>
  .archive-layout {
    display: flex;
    justify-content: space-between;
    gap: 60px;
    max-width: 1000px;
    margin: 0 auto;
    padding: 80px 24px;
    box-sizing: border-box;
  }

  .archive-main {
    flex: 1;
    max-width: 680px;
    min-width: 0;
    display: flex;
    flex-direction: column;
    gap: 30px;
  }

  /* 标题与分类区域重构 */
  .archive-title-section {
    text-align: left;
    margin-bottom: 10px;
    position: relative;
  }
  .archive-title-section .sub-title {
    font-size: 0.7em;
    letter-spacing: 2.5px;
    color: var(--text-muted);
    font-weight: 600;
  }
  
  /* 动态标题过渡动画 */
  .title-transition {
    transition: opacity 0.2s ease, transform 0.2s ease;
    opacity: 1;
    transform: translateY(0);
    font-size: 2.2rem;
    margin: 5px 0 15px 0;
    color: var(--text-color);
  }
  .title-transition.fade-out {
    opacity: 0;
    transform: translateY(-8px);
  }

  /* 分类筛选器 UI */
  .category-filters {
    display: flex;
    gap: 12px;
    margin-top: 10px;
  }
  .cat-btn {
    font-size: 0.85rem;
    color: var(--text-muted);
    cursor: pointer;
    padding: 4px 12px;
    border-radius: 20px;
    background: rgba(128, 128, 128, 0.05);
    transition: all 0.3s ease;
  }
  .cat-btn:hover {
    color: var(--text-color);
    background: rgba(128, 128, 128, 0.1);
  }
  .cat-btn.active {
    color: #fff;
    background: var(--accent-color);
    font-weight: 500;
    box-shadow: 0 2px 6px rgba(227, 13, 49, 0.2);
  }

  /* 核心动画点：不使用 display:none，使用 max-height 与 scale 折叠 */
  .post-item {
    display: block !important;
    opacity: 1;
    max-height: 500px;
    transform: translateY(0) scale(1);
    overflow: hidden;
    padding-bottom: 25px;
    margin-bottom: 0;
    border-bottom: 1px dashed var(--border-color);
    text-align: left;
    transition: 
      opacity 0.4s cubic-bezier(0.25, 1, 0.5, 1),
      transform 0.4s cubic-bezier(0.25, 1, 0.5, 1),
      max-height 0.4s cubic-bezier(0.25, 1, 0.5, 1),
      padding 0.4s cubic-bezier(0.25, 1, 0.5, 1),
      border-color 0.4s ease;
  }

  .post-item.filtered-out {
    opacity: 0 !important;
    max-height: 0 !important;
    transform: translateY(-15px) scale(0.95) !important;
    padding-bottom: 0 !important;
    margin-bottom: 0 !important;
    border-bottom-color: transparent !important;
    pointer-events: none;
  }

  .pinned-item {
    border-bottom-style: solid;
  }
  .pinned-item h2 {
    font-size: 1.55rem;
    margin: 0 0 8px 0;
    font-weight: 500;
  }
  .pinned-item h2 a, .post-item h3 a {
    color: var(--text-color) !important;
    text-decoration: none;
    transition: color 0.2s;
  }
  .pinned-item h2 a:hover, .post-item h3 a:hover {
    color: var(--accent-color) !important;
  }

  .pinned-tag {
    background: rgba(244, 63, 94, 0.08) !important;
    color: var(--accent-color) !important;
    font-size: 0.72rem;
    padding: 2px 8px;
    border-radius: 4px;
    font-weight: 500;
    letter-spacing: 1px;
  }

  .pinned-tag-mini {
    background: rgba(128, 128, 128, 0.08) !important;
    color: var(--text-muted) !important;
    font-size: 0.72rem;
    padding: 1px 6px;
    border-radius: 4px;
    font-weight: 500;
  }

  .post-desc {
    margin: 0;
    font-size: 0.88rem;
    line-height: 1.6;
    color: var(--text-color);
    opacity: 0.8;
  }

  .archive-post-meta {
    font-size: 0.78rem;
    color: var(--text-muted);
    display: flex;
    align-items: center;
    gap: 12px;
    flex-wrap: wrap;
    margin-top: 4px;
  }

  .list-control-bar {
    display: flex;
    justify-content: space-between;
    align-items: center;
    font-size: 0.8rem;
    border-bottom: 1px solid var(--border-color);
    padding-bottom: 12px;
    margin-top: 5px;
    color: var(--text-muted);
  }

  .sort-options {
    display: flex;
    gap: 15px;
  }

  .sort-btn {
    cursor: pointer;
    transition: color 0.2s;
  }
  .sort-btn:hover, .sort-btn.active {
    color: var(--accent-color);
    font-weight: 500;
  }

  .regular-posts-list {
    display: flex;
    flex-direction: column;
    gap: 10px;
    transition: opacity 0.2s ease;
  }
  .regular-posts-list.sorting-transition {
    opacity: 0.3;
  }

  .tag-pill {
    background: rgba(128, 128, 128, 0.08);
    color: var(--text-muted);
    padding: 1px 8px;
    border-radius: 10px;
    font-size: 0.72rem;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .tag-pill:hover {
    background: rgba(227, 13, 49, 0.1);
    color: var(--accent-color);
  }

  /* 右侧侧边栏 */
  .archive-sidebar {
    width: 220px;
  }
  .sidebar-sticky-card {
    position: sticky;
    top: 100px;
    height: fit-content;
    display: flex;
    flex-direction: column;
    gap: 30px;
    text-align: left;
  }

  .search-box-wrapper {
    display: flex;
    align-items: center;
    gap: 8px;
    background: rgba(128, 128, 128, 0.05);
    border: 1px solid var(--border-color);
    padding: 8px 14px;
    border-radius: 8px;
    color: var(--text-muted);
    transition: border-color 0.3s ease;
  }
  .search-box-wrapper:focus-within {
    border-color: var(--accent-color);
  }
  .search-icon {
    flex-shrink: 0;
  }
  .search-box-wrapper input {
    background: none;
    border: none;
    outline: none;
    width: 100%;
    font-size: 0.82rem;
    color: var(--text-color);
    font-family: inherit;
  }

  .sidebar-section {
    display: flex;
    flex-direction: column;
    gap: 15px;
  }
  .section-title {
    font-size: 0.8rem;
    font-weight: bold;
    letter-spacing: 1px;
    color: var(--text-muted);
  }

  .tags-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
  }
  .tag-badge {
    background: rgba(128, 128, 128, 0.05);
    border: 1px solid var(--border-color);
    color: var(--text-muted);
    font-size: 0.75rem;
    padding: 3px 10px;
    border-radius: 6px;
    cursor: pointer;
    transition: all 0.2s ease;
  }
  .tag-badge:hover {
    color: var(--accent-color);
    border-color: var(--accent-color);
    transform: translateY(-1px);
  }
  .tag-badge.active {
    background: var(--accent-color) !important;
    color: #fff !important;
    border-color: var(--accent-color) !important;
    transform: translateY(-1px);
    box-shadow: 0 2px 5px rgba(227, 13, 49, 0.2);
  }
  .tag-count {
    font-size: 0.7rem;
    opacity: 0.7;
  }
  .all-tags-link {
    font-size: 0.75rem;
    color: var(--text-muted);
    text-decoration: none;
    transition: color 0.2s;
  }
  .all-tags-link:hover {
    color: var(--text-color);
  }
  /* 分区介绍小字样式 */
  .category-desc {
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-top: 15px; /* 与上方过滤按钮的间距 */
    line-height: 1.6;
    letter-spacing: 0.5px;
    font-style: italic; /* 如果不需要斜体可以删掉这行 */
  }

  @media (max-width: 768px) {
    .archive-layout {
      flex-direction: column;
      padding: 40px 20px;
    }
    .archive-sidebar {
      display: none;
    }
  }
</style>