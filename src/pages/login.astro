---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="身份验证 - Yutachi">

  <div class="login-container">

    <header class="login-header">
      <span class="sub-title">AUTHENTICATION</span>

      <h1 class="serif-font" id="page-title">
        扉
      </h1>

      <p class="login-desc" id="page-desc">
        请输入凭证登录
      </p>
    </header>


    <div class="login-form-box">

      <div class="input-group">
        <input
          type="email"
          id="email"
          placeholder="邮箱"
          autocomplete="email"
          required
        />
      </div>


      <div class="input-group">
        <input
          type="password"
          id="password"
          placeholder="密码（至少6位）"
          minlength="6"
          autocomplete="current-password"
          required
        />
      </div>


      <button
        type="button"
        id="submit-btn"
        class="login-submit-btn serif-font">
        登 录
      </button>


      <button
        type="button"
        id="toggle-mode-btn"
        class="register-toggle-btn">
        没有账号？点击注册
      </button>


      <p id="msg" class="error-msg"></p>


    </div>

  </div>

</BaseLayout>



<script>
import { createClient } from '@supabase/supabase-js';


const supabase = createClient(
  import.meta.env.PUBLIC_SUPABASE_URL,
  import.meta.env.PUBLIC_SUPABASE_ANON_KEY
);



let initialized = false;


function initAuth(){

  if(initialized) return;

  initialized = true;



  const submitBtn =
    document.getElementById(
      "submit-btn"
    ) as HTMLButtonElement | null;


  const toggleBtn =
    document.getElementById(
      "toggle-mode-btn"
    ) as HTMLButtonElement | null;


  const msgEl =
    document.getElementById(
      "msg"
    ) as HTMLParagraphElement | null;


  const titleEl =
    document.getElementById(
      "page-title"
    );


  const descEl =
    document.getElementById(
      "page-desc"
    );



  const emailInput =
    document.getElementById(
      "email"
    ) as HTMLInputElement | null;


  const passwordInput =
    document.getElementById(
      "password"
    ) as HTMLInputElement | null;



  if(
    !submitBtn ||
    !toggleBtn ||
    !msgEl ||
    !emailInput ||
    !passwordInput
  ){
    return;
  }



  let loginMode = true;



  toggleBtn.onclick = ()=>{


    loginMode = !loginMode;


    msgEl.innerText="";



    if(loginMode){

      titleEl!.innerText="扉";

      descEl!.innerText=
        "请输入凭证登录";

      submitBtn.innerText=
        "登 录";

      toggleBtn.innerText=
        "没有账号？点击注册";


    }else{


      titleEl!.innerText=
        "新 兵";


      descEl!.innerText=
        "创建您的凭证";


      submitBtn.innerText=
        "注 册";


      toggleBtn.innerText=
        "已有账号？返回登录";

    }

  };





  submitBtn.onclick = async ()=>{


    const email =
      emailInput.value.trim();


    const password =
      passwordInput.value.trim();




    if(!email || !password){

      msgEl.style.color="#f43f5e";

      msgEl.innerText=
        "请填写完整信息";

      return;

    }



    if(password.length < 6){

      msgEl.style.color="#f43f5e";

      msgEl.innerText=
        "密码至少需要6位";

      return;

    }




    submitBtn.disabled=true;

    submitBtn.innerText=
      "处理中...";




    try{


      let error;



      if(loginMode){


        const result =
          await supabase.auth
          .signInWithPassword({

            email,

            password

          });


        error=result.error;



      }else{


        const result =
          await supabase.auth
          .signUp({

            email,

            password

          });


        error=result.error;



        if(!error){

          msgEl.style.color=
            "var(--accent-color)";


          msgEl.innerText=
            "注册成功，请检查邮箱验证";


          submitBtn.disabled=false;

          submitBtn.innerText=
            "注 册";


          return;

        }

      }




      if(error){

        throw error;

      }





      msgEl.style.color=
        "var(--accent-color)";


      msgEl.innerText=
        "验证成功，正在进入...";



      setTimeout(()=>{

        window.location.href="/";

      },1000);



    }catch(err){


      msgEl.style.color=
        "#f43f5e";


      msgEl.innerText=
        err instanceof Error
        ? err.message
        : "未知错误";



      submitBtn.disabled=false;


      submitBtn.innerText =
        loginMode
        ? "登 录"
        : "注 册";


    }


  };


}




initAuth();


document.addEventListener(
  "astro:page-load",
  initAuth
);

</script>





<style>

.login-container{

  max-width:400px;

  margin:120px auto;

  padding:0 24px;

  text-align:center;

}



.login-header{

  margin-bottom:50px;

}



.sub-title{

  font-size:.7rem;

  letter-spacing:3px;

  color:var(--text-muted);

}



.login-header h1{

  font-size:3rem;

  margin:15px 0;

  color:var(--text-color);

  font-weight:400;

}



.login-desc{

  font-size:.85rem;

  color:var(--text-muted);

}



.login-form-box{

  display:flex;

  flex-direction:column;

  gap:20px;

}




.input-group input{

  width:100%;

  background:transparent;

  border:none;

  border-bottom:
    1px solid var(--border-color);


  padding:12px 0;


  color:var(--text-color);


  font-family:inherit;


  font-size:.95rem;


  outline:none;

}




.input-group input:focus{

  border-bottom-color:
    var(--accent-color);

}




.login-submit-btn{


  margin-top:20px;


  background:transparent;


  border:
    1px solid var(--text-color);


  color:var(--text-color);


  padding:12px;


  cursor:pointer;


  font-size:1rem;


  letter-spacing:4px;


  transition:.3s;

}




.login-submit-btn:hover{


  background:
    var(--text-color);


  color:
    var(--bg-color);


}




.error-msg{


  min-height:1.2em;


  font-size:.8rem;


}




.register-toggle-btn{


  background:none;


  border:none;


  color:
    var(--text-muted);


  cursor:pointer;


  text-decoration:underline;


  font-size:.85rem;


}



.register-toggle-btn:hover{


  color:
    var(--accent-color);


}


</style>